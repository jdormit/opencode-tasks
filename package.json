{
  "name": "opencode-scheduler",
  "version": "0.1.0",
  "description": "Scheduled task runner plugin for OpenCode - cron-based recurring and one-off task scheduling",
  "type": "module",
  "main": "./dist/plugin.js",
  "module": "./dist/plugin.js",
  "types": "./dist/plugin.d.ts",
  "exports": {
    ".": {
      "import": "./dist/plugin.js",
      "types": "./dist/plugin.d.ts"
    }
  },
  "bin": {
    "opencode-scheduler": "dist/cli.js"
  },
  "files": [
    "dist",
    "examples",
    "skill"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "opencode",
    "scheduler",
    "cron",
    "tasks",
    "automation",
    "plugin"
  ],
  "author": "Jeremy Dormitzer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jdormit/opencode-scheduler.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cron-parser": "^5.0.0",
    "gray-matter": "^4.0.3"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=0.15.0"
  },
  "peerDependenciesMeta": {
    "@opencode-ai/plugin": {
      "optional": true
    }
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.0.0",
    "@opencode-ai/sdk": "^1.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  }
}
